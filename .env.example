APP_NAME=Education Intelligent Agent
APP_HOST=127.0.0.1
APP_PORT=8000

# OpenAI 或兼容 OpenAI API 的模型服务
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini

# Embedding 默认走本地 bge-m3；只有显式设为 openai 时才使用 OPENAI_API_KEY + EMBEDDING_MODEL。
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-3-small

# 本地 sentence-transformers embedding 模型。
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3

DATABASE_URL=sqlite:///./data/app.db
UPLOAD_DIR=./data/uploads
CHROMA_DIR=./data/chroma
CHROMA_COLLECTION=course_chunks_bge_m3
CHUNK_SIZE=900
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5

LOCAL_EMBEDDING_MAX_SEQ_LENGTH=2048
EMBEDDING_MAX_CHARS=6000
RETRIEVAL_MIN_SCORE=0.50
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RETRIEVAL_MAX_PER_MATERIAL=1
RETRIEVAL_MAX_PER_DOCUMENT=2
QUESTION_RENDER_OCR_ENABLED=true
QUESTION_RENDER_OCR_IMAGE_ONLY=true